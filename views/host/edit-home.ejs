<%- include('../partials/head') %>
  </head>

  <body>
    <%- include('../partials/nav', {isLoggedIn}) %>
      <main class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto">
          <div class="bg-white rounded-2xl shadow-lg p-8">
            <% if (locals.editing) { %>
              <div class="mb-8">
                <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Listing</h1>
                <p class="text-gray-600">Update your home details</p>
              </div>
              <form action="/host/edit-home" method="POST" enctype="multipart/form-data" class="space-y-6">
                <input type="hidden" value="<%= home._id %>" name="_id">

                <div>
                  <label for="name" class="block text-sm font-semibold text-gray-900 mb-2">Home Name</label>
                  <input id="name" type="text" name="name" value="<%= home.name %>" placeholder="Enter your house name"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                </div>

                <div>
                  <label for="description" class="block text-sm font-semibold text-gray-900 mb-2">Description</label>
                  <textarea id="description" name="description" placeholder="Describe your home" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition h-24 resize-none"><%= home.description %></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="price" class="block text-sm font-semibold text-gray-900 mb-2">Price per Night
                      (₹)</label>
                    <input id="price" type="number" name="price" value="<%= home.price %>" placeholder="0" required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                  </div>
                  <div>
                    <label for="ratings" class="block text-sm font-semibold text-gray-900 mb-2">Rating (0-5)</label>
                    <input id="ratings" type="number" name="ratings" value="<%= home.ratings %>" placeholder="0"
                      step="0.1" min="0" max="5" required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                  </div>
                </div>

                <div>
                  <label for="photo" class="block text-sm font-semibold text-gray-900 mb-2">Image URL</label>
                  <input id="photo" type="file" name="photo" accept="image/jpg, image/jpeg, image/png" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                </div>

                <div>
                  <label for="location" class="block text-sm font-semibold text-gray-900 mb-2">Location</label>
                  <input id="location" type="text" name="location" value="<%= home.location %>"
                    placeholder="Enter location of your house" required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                </div>

                <div class="flex gap-3 pt-4">
                  <input type="submit" value="Save Changes"
                    class="flex-1 bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white font-semibold py-3 rounded-lg transition duration-300 cursor-pointer" />
                  <a href="/host/home-list"
                    class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-900 font-semibold py-3 rounded-lg transition duration-300 text-center">
                    Cancel
                  </a>
                </div>
              </form>
              <% } else { %>
                <div class="mb-8">
                  <h1 class="text-3xl font-bold text-gray-900 mb-2">List Your Home on AirBnB</h1>
                  <p class="text-gray-600">Share your property and start earning</p>
                </div>
                <form action="/host/add-home" method="POST" enctype="multipart/form-data" class="space-y-6">
                  <div>
                    <label for="name" class="block text-sm font-semibold text-gray-900 mb-2">Home Name</label>
                    <input id="name" type="text" name="name" placeholder="Enter your house name" required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                  </div>

                  <div>
                    <label for="description" class="block text-sm font-semibold text-gray-900 mb-2">Description</label>
                    <textarea id="description" name="description" placeholder="Describe your home and its features" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition h-24 resize-none"></textarea>
                  </div>

                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label for="price" class="block text-sm font-semibold text-gray-900 mb-2">Price per Night
                        (₹)</label>
                      <input id="price" type="number" name="price" placeholder="0" required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                    </div>
                    <div>
                      <label for="ratings" class="block text-sm font-semibold text-gray-900 mb-2">Rating (0-5)</label>
                      <input id="ratings" type="number" name="ratings" placeholder="0" step="0.1" min="0" max="5"
                        required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                    </div>
                  </div>

                  <div>
                    <label for="photo" class="block text-sm font-semibold text-gray-900 mb-2">Image URL</label>
                    <input id="photo" type="file" name="photo" accept="image/jpg, image/jpeg, image/png" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                  </div>

                  <div>
                    <label for="location" class="block text-sm font-semibold text-gray-900 mb-2">Location</label>
                    <input id="location" type="text" name="location" placeholder="Enter location of your house" required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition" />
                  </div>

                  <input type="submit" value="Create Listing"
                    class="w-full bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white font-semibold py-3 rounded-lg transition duration-300 cursor-pointer" />
                </form>
                <% } %>
          </div>
        </div>
      </main>
  </body>

  </html>