<%- include('../partials/head') %>
  </head>

  <body>
    <%- include('../partials/nav', {isLoggedIn}) %>
      <main class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
          <!-- Header Section -->
          <div class="mb-12">
            <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-3 flex items-center space-x-3">
              <svg class="w-10 h-10 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
              <span>My Listings</span>
            </h1>
            <p class="text-lg text-gray-600">Manage and monitor your registered properties</p>
            <a href="/host/add-home"
              class="inline-block mt-6 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-300 flex items-center space-x-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              <span>Add New Listing</span>
            </a>
          </div>

          <!-- Homes Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% registeredHomes.forEach(home=> { %>
              <div
                class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-2xl transition-all duration-300 group">
                <!-- Image Container -->
                <div class="relative overflow-hidden h-56 bg-gray-200">
                  <img src=<%=home.photo ? "/uploads/homes/" + home.photo : "/images/default-home.png" %> alt="<%=
                    home.name %>"
                    class="w-full h-full object-cover group-hover:scale-110 transition duration-300">
                    <div
                      class="absolute top-3 right-3 bg-white bg-opacity-90 rounded-full px-3 py-1 flex items-center space-x-1 text-sm font-semibold">
                      <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                        <path
                          d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                      <span>
                        <%= home.ratings %>
                      </span>
                    </div>
                </div>

                <!-- Content -->
                <div class="p-5">
                  <h3 class="text-xl font-bold text-gray-900 mb-2 line-clamp-2">
                    <%= home.name %>
                  </h3>
                  <div class="flex items-center text-gray-500 text-sm mb-3">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd"
                        d="M5.05 4.05a7 7 0 119.9 9.9L9.9 13.95a7 7 0 01-9.9-9.9zM9 11a2 2 0 100-4 2 2 0 000 4z"
                        clip-rule="evenodd" />
                    </svg>
                    <%= home.location %>
                  </div>
                  <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                    <%= home.description %>
                  </p>

                  <!-- Price & Actions -->
                  <div class="border-t border-gray-200 pt-4">
                    <div class="mb-4">
                      <span class="text-2xl font-bold text-amber-600">₹<%= home.price %></span>
                      <span class="text-gray-600 text-sm ml-1">/night</span>
                    </div>
                    <form class="flex gap-2" action="/host/delete-home/<%= home._id %>" method="post">
                      <a href="/host/edit-home/<%= home._id %>?editing=true"
                        class="flex-1 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-300 flex items-center justify-center space-x-2 text-center">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        <span>Edit</span>
                      </a>
                      <button type="submit"
                        class="flex-1 bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-300 flex items-center justify-center space-x-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        <span>Delete</span>
                      </button>
                    </form>
                  </div>
                </div>
              </div>
              <% }) %>
          </div>
        </div>
      </main>
  </body>

  </html>