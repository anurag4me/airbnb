<%- include('../partials/head') %>
    </head>

    <body>
        <%- include('../partials/nav', {isLoggedIn}) %>
            <main class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 py-12 px-4 sm:px-6 lg:px-8">
                <div class="max-w-6xl mx-auto">
                    <!-- Back Button -->
                    <a href="/homes"
                        class="inline-flex items-center space-x-2 text-rose-600 hover:text-rose-700 mb-8 font-semibold">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                        <span>Back to Homes</span>
                    </a>

                    <!-- Main Content -->
                    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
                            <!-- Image Section -->
                            <div class="rounded-xl overflow-hidden">
                                <img src="<%= home.photo %>" alt="<%= home.name %>"
                                    class="w-full h-96 object-cover hover:scale-105 transition duration-300">
                            </div>

                            <!-- Details Section -->
                            <div class="space-y-6">
                                <div>
                                    <h1 class="text-4xl font-bold text-gray-900 mb-2">
                                        <%= home.name %>
                                    </h1>
                                    <div class="flex items-center space-x-4">
                                        <div class="flex items-center space-x-1">
                                            <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                                                <path
                                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                            </svg>
                                            <span class="font-semibold text-gray-900">
                                                <%= home.ratings %> / 5
                                            </span>
                                        </div>
                                        <div class="flex items-center space-x-1 text-gray-600">
                                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd"
                                                    d="M5.05 4.05a7 7 0 119.9 9.9L9.9 13.95a7 7 0 01-9.9-9.9zM9 11a2 2 0 100-4 2 2 0 000 4z"
                                                    clip-rule="evenodd" />
                                            </svg>
                                            <span>
                                                <%= home.location %>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Description -->
                                <div class="border-t border-b border-gray-200 py-6">
                                    <h3 class="text-lg font-semibold text-gray-900 mb-3">About this Home</h3>
                                    <p class="text-gray-600 leading-relaxed">
                                        <%= home.description %>
                                    </p>
                                </div>

                                <!-- Price Section -->
                                <div class="bg-gradient-to-r from-rose-50 to-pink-50 rounded-xl p-6">
                                    <p class="text-gray-600 text-sm mb-1">Price per night</p>
                                    <h2 class="text-5xl font-bold text-rose-600 mb-4">
                                        ₹<%= home.price %>
                                    </h2>
                                    <button
                                        class="w-full bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white font-bold py-4 rounded-lg transition duration-300 flex items-center justify-center space-x-2">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M5 13l4 4L19 7" />
                                        </svg>
                                        <span>Reserve Now</span>
                                    </button>
                                </div>

                                <!-- Action Buttons -->
                                <div class="flex gap-3">
                                    <%- include('../partials/favourite') %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
    </body>

    </html>