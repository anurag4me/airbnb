<%- include('../partials/head') %>
  </head>

  <body>
    <%- include('../partials/nav', {isLoggedIn}) %>
      <main class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
          <% if(favouriteHomes.length <=0) { %>
            <div class="text-center py-16">
              <div class="mb-6">
                <svg class="w-24 h-24 mx-auto text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              </div>
              <h2 class="text-3xl font-bold text-gray-900 mb-3">Your Favorites List is Empty</h2>
              <p class="text-gray-600 mb-8 max-w-2xl mx-auto">Start exploring and add homes to your favorites to save
                them for later</p>
              <a href="/homes"
                class="inline-block bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white font-semibold py-3 px-8 rounded-lg transition duration-300">
                Explore Homes
              </a>
            </div>
            <% } else { %>
              <!-- Header -->
              <div class="mb-12">
                <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-3 flex items-center space-x-3">
                  <svg class="w-10 h-10 text-rose-500" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" />
                  </svg>
                  <span>My Favorite Homes</span>
                </h1>
                <p class="text-lg text-gray-600">
                  <%= favouriteHomes.length %> home<%= favouriteHomes.length> 1 ? 's' : '' %> saved
                </p>
              </div>

              <!-- Homes Grid -->
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% favouriteHomes.forEach(home=> { %>
                  <div
                    class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:scale-105 group">
                    <!-- Image Container -->
                    <div class="relative overflow-hidden h-56 bg-gray-200">
                      <img src="<%= home.photo %>" alt="<%= home.name %>"
                        class="w-full h-full object-cover group-hover:scale-110 transition duration-300">
                      <div
                        class="absolute top-3 right-3 bg-white bg-opacity-90 rounded-full px-3 py-1 flex items-center space-x-1 text-sm font-semibold">
                        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                          <path
                            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                        <span>
                          <%= home.ratings %>
                        </span>
                      </div>
                      <div
                        class="absolute top-3 left-3 bg-rose-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                        ♥ Favorite
                      </div>
                    </div>

                    <!-- Content -->
                    <div class="p-5">
                      <h3 class="text-xl font-bold text-gray-900 mb-2 line-clamp-2">
                        <%= home.name %>
                      </h3>
                      <div class="flex items-center text-gray-500 text-sm mb-4">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd"
                            d="M5.05 4.05a7 7 0 119.9 9.9L9.9 13.95a7 7 0 01-9.9-9.9zM9 11a2 2 0 100-4 2 2 0 000 4z"
                            clip-rule="evenodd" />
                        </svg>
                        <%= home.location %>
                      </div>

                      <!-- Price & Actions -->
                      <div class="border-t border-gray-200 pt-4">
                        <div class="mb-4">
                          <span class="text-2xl font-bold text-rose-600">₹<%= home.price %></span>
                          <span class="text-gray-600 text-sm ml-1">/night</span>
                        </div>
                        <form class="flex gap-2" action="/delete-favourite/<%= home._id %>" method="post">
                          <button type="submit"
                            class="flex-1 bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-300 flex items-center justify-center space-x-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                            <span>Remove</span>
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                  <% }) %>
              </div>
              <% } %>
        </div>
      </main>
  </body>

  </html>