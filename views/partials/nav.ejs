<header class="bg-gradient-to-r from-rose-600 to-rose-500 text-white sticky top-0 z-50 shadow-lg">
  <nav class="container mx-auto flex justify-between items-center px-6 py-4">
    <!-- Logo & Brand -->
    <div class="flex items-center space-x-2 mr-4">
      <a href="/" class="flex items-center space-x-2 hover:opacity-90 transition">
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
        </svg>
        <span class="text-2xl font-bold tracking-tight">AirBnb</span>
      </a>
    </div>

    <!-- Navigation Links -->
    <ul class="hidden md:flex space-x-1">
      <% if (isLoggedIn) { %>
        <li>
          <a href="/homes"
            class="py-2 px-4 rounded-lg transition duration-300 flex items-center space-x-1 <%= currentPath === '/homes' ? 'bg-rose-700 font-semibold' : 'hover:bg-rose-400' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 13l4-8m4 8V9" />
            </svg>
            <span>Homes</span>
          </a>
        </li>
        <li>
          <a href="/bookings"
            class="py-2 px-4 rounded-lg transition duration-300 flex items-center space-x-1 <%= currentPath === '/bookings' ? 'bg-rose-700 font-semibold' : 'hover:bg-rose-400' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span>Bookings</span>
          </a>
        </li>
        <li>
          <a href="/favourites"
            class="py-2 px-4 rounded-lg transition duration-300 flex items-center space-x-1 <%= currentPath === '/favourites' ? 'bg-rose-700 font-semibold' : 'hover:bg-rose-400' %>">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
            <span>Favorites</span>
          </a>
        </li>
        <li class="border-l border-rose-400"></li>
        <li>
          <a href="/host/add-home"
            class="py-2 px-4 rounded-lg transition duration-300 flex items-center space-x-1 bg-amber-500 hover:bg-amber-600 <%= currentPath === '/host/add-home' ? 'font-semibold' : '' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span>List Home</span>
          </a>
        </li>
        <li>
          <a href="/host/home-list"
            class="py-2 px-4 rounded-lg transition duration-300 flex items-center space-x-1 <%= currentPath === '/host/home-list' ? 'bg-rose-700 font-semibold' : 'hover:bg-rose-400' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2" />
            </svg>
            <span>My Homes</span>
          </a>
        </li>
        <% } %>
    </ul>

    <!-- Hamburger Button (Mobile) -->
    <button id="hamburger-btn"
      class="md:hidden flex items-center text-white hover:bg-rose-400 rounded-lg p-2 transition duration-300">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Auth Links -->
    <ul class="hidden md:flex items-center space-x-2">
      <% if (isLoggedIn) { %>
        <li>
          <form action="/logout" method="post" class="m-0">
            <button
              class="py-2 px-4 rounded-lg transition duration-300 bg-rose-700 hover:bg-rose-800 font-semibold text-white">
              Logout
            </button>
          </form>
        </li>
        <% } else { %>
          <li>
            <a href="/login" class="py-2 px-4 rounded-lg transition duration-300 hover:bg-rose-400 font-medium text-sm">
              Login
            </a>
          </li>
          <li>
            <a href="/signup"
              class="py-2 px-4 rounded-lg bg-white text-rose-600 hover:bg-gray-100 font-semibold text-sm">
              Sign Up
            </a>
          </li>
          <% } %>
    </ul>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-rose-700 px-6 py-4 space-y-2">
    <% if (isLoggedIn) { %>
      <a href="/homes"
        class="block py-2 px-4 rounded-lg transition duration-300 <%= currentPath === '/homes' ? 'bg-rose-800 font-semibold' : 'hover:bg-rose-600' %>">
        Homes
      </a>
      <a href="/bookings"
        class="block py-2 px-4 rounded-lg transition duration-300 <%= currentPath === '/bookings' ? 'bg-rose-800 font-semibold' : 'hover:bg-rose-600' %>">
        Bookings
      </a>
      <a href="/favourites"
        class="block py-2 px-4 rounded-lg transition duration-300 <%= currentPath === '/favourites' ? 'bg-rose-800 font-semibold' : 'hover:bg-rose-600' %>">
        Favorites
      </a>
      <div class="border-t border-rose-500 py-2"></div>
      <a href="/host/add-home"
        class="block py-2 px-4 rounded-lg transition duration-300 bg-amber-500 hover:bg-amber-600 <%= currentPath === '/host/add-home' ? 'font-semibold' : '' %>">
        List Home
      </a>
      <a href="/host/home-list"
        class="block py-2 px-4 rounded-lg transition duration-300 <%= currentPath === '/host/home-list' ? 'bg-rose-800 font-semibold' : 'hover:bg-rose-600' %>">
        My Homes
      </a>
      <div class="border-t border-rose-500 py-2"></div>
      <form action="/logout" method="post" class="m-0">
        <button
          class="w-full text-left py-2 px-4 rounded-lg transition duration-300 bg-rose-800 hover:bg-rose-900 font-semibold">
          Logout
        </button>
      </form>
      <% } else { %>
        <a href="/login" class="block py-2 px-4 rounded-lg transition duration-300 hover:bg-rose-600">
          Login
        </a>
        <a href="/signup" class="block py-2 px-4 rounded-lg bg-white text-rose-600 hover:bg-gray-100 font-semibold">
          Sign Up
        </a>
        <% } %>
  </div>
</header>

<script>
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburgerBtn.addEventListener('click', function () {
    mobileMenu.classList.toggle('hidden');
  });

  // Close menu when clicking on a link
  const menuLinks = mobileMenu.querySelectorAll('a, button');
  menuLinks.forEach(link => {
    link.addEventListener('click', function () {
      mobileMenu.classList.add('hidden');
    });
  });
</script>